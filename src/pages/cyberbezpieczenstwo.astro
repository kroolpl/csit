---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const threats = [
  { title: 'Ransomware', desc: 'Złośliwe oprogramowanie szyfruje dane i żąda okupu. Skuteczna kopia zapasowa to jedyna ochrona.' },
  { title: 'Phishing', desc: 'Fałszywe e-maile wyłudzające hasła. Jeden klik pracownika może kosztować firmę fortunę.' },
  { title: 'Ataki na sieć', desc: 'Niechronione Wi-Fi i brak firewalla to otwarte drzwi dla hakerów działających niezauważenie.' },
  { title: 'Wycieki danych', desc: 'Utrata danych klientów to nie tylko strata finansowa, ale i poważne naruszenie RODO.' }
];

const cyberServices = [
  { title: 'Audyt bezpieczeństwa IT', desc: 'Oceniamy stan zabezpieczeń, wskazujemy luki i rekomendujemy konkretne działania.' },
  { title: 'Firewall i ochrona sieci', desc: 'Profesjonalna konfiguracja zapory sieciowej, segmentacja sieci i ochrona punktów końcowych.' },
  { title: 'Backup i Disaster Recovery', desc: 'Wdrażamy strategie kopii zapasowych (NAS, chmura) i regularnie testujemy odtwarzanie.' },
  { title: 'Szkolenia pracowników', desc: 'Świadomy zespół to najlepsza obrona przed socjotechniką i phishingiem.' }
];
---

<Layout 
  title="Cyberbezpieczeństwo i Ochrona Danych | Małopolska" 
  description="Profesjonalne zabezpieczenia IT, audyty bezpieczeństwa i kopie zapasowe dla firm w Tarnowie. Chroń swój biznes przed hakerami. Tel: 504 365 205."
>
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO -->
    <header class="py-24 lg:py-40 bg-white relative overflow-hidden">
      <div class="container-custom relative z-10">
        <span class="technical-label mb-6 block">Ochrona firm i sieci w Małopolsce</span>
        <h1 class="text-5xl lg:text-8xl font-display font-bold text-brand-secondary leading-[0.9] mb-8 max-w-4xl">
          Hakerzy nie śpią.<br/><span class="text-brand-primary">Twoja firma nie powinna być łatwym celem.</span>
        </h1>
        <p class="text-xl lg:text-2xl text-slate-600 max-w-2xl mb-12 leading-relaxed">
          Ataki ransomware, phishing i wycieki danych to realne zagrożenia. Oferujemy profesjonalne zabezpieczenia, które realnie chronią Twój biznes.
        </p>
        <a href="tel:504365205" class="bg-brand-primary text-white px-10 py-5 rounded-sm font-display font-bold text-lg inline-flex items-center gap-4 hover:bg-brand-secondary transition-all shadow-xl">
          → Umów audyt bezpieczeństwa
        </a>
      </div>
      <!-- Background pattern -->
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none select-none overflow-hidden font-mono text-[10px] leading-none text-slate-900 break-all p-4">
        {Array.from({length: 50}).map(() => "01001010110101010101010101010101011101010101010101010101010101010111010101010101010101010101010101")}
      </div>
    </header>

    <!-- THREATS -->
    <section class="py-32 bg-slate-900 text-white">
      <div class="container-custom">
        <div class="mb-20 text-center">
          <span class="technical-label text-brand-primary mb-4 block">Znasz te zagrożenia?</span>
          <h2 class="text-4xl lg:text-6xl font-display font-bold">Twoja firma jest narażona codziennie</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {threats.map(t => (
            <div class="p-10 border border-white/10 bg-white/5 hover:border-brand-primary transition-colors">
              <h4 class="text-xl font-display font-bold mb-4">{t.title}</h4>
              <p class="text-white/60 text-sm leading-relaxed">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="py-32 bg-white">
      <div class="container-custom">
        <div class="mb-20">
          <span class="technical-label mb-4 block">Jak Cię chronimy</span>
          <h2 class="text-4xl lg:text-6xl font-display font-bold text-brand-secondary leading-tight">Kompleksowe cyberbezpieczeństwo</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-px bg-slate-200 border border-slate-200">
          {cyberServices.map(s => (
            <div class="bg-white p-12 hover:bg-slate-50 transition-colors">
              <h3 class="text-2xl font-display font-bold text-brand-secondary mb-6">{s.title}</h3>
              <p class="text-slate-600 leading-relaxed mb-8">{s.desc}</p>
              <div class="w-12 h-1 bg-brand-primary"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- NAS & BACKUP -->
    <section class="py-32 bg-slate-50 border-y border-slate-200">
      <div class="container-custom">
        <div class="flex flex-col lg:flex-row gap-20 items-center">
          <div class="lg:w-1/2">
             <span class="technical-label mb-4 block">Serwery NAS i kopie zapasowe</span>
             <h2 class="text-4xl lg:text-5xl font-display font-bold text-brand-secondary mb-8">Twoje dane muszą mieć kopię. Zawsze.</h2>
             <p class="text-xl text-slate-600 mb-8 leading-relaxed">
               Wdrażamy serwery NAS (m.in. Synology) i rozwiązania chmurowe, które automatycznie tworzą kopie zapasowe Twoich danych.
             </p>
             <ul class="space-y-4">
                {['Lokalne przechowywanie - pełna kontrola', 'Automatyczne kopie komputerów i serwerów', 'Szyfrowanie i ochrona przed dostępem'].map(item => (
                  <li class="flex items-center gap-4 text-slate-700 font-medium">
                    <svg class="text-brand-primary" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    {item}
                  </li>
                ))}
             </ul>
          </div>
          <div class="lg:w-1/2 bg-white p-12 border border-slate-200 shadow-2xl relative">
             <div class="technical-label text-[8px] mb-6">Backup System Status: Active</div>
             <div class="space-y-4">
                <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                   <div class="h-full bg-brand-primary w-full animate-pulse"></div>
                </div>
                <div class="flex justify-between text-[10px] font-mono uppercase tracking-widest text-slate-400">
                   <span>Encrypted</span>
                   <span>Verified</span>
                   <span>Redundant</span>
                </div>
             </div>
             <div class="mt-12 text-brand-secondary font-display font-bold">
                Wdrożyliśmy ponad 500 TB bezpiecznej przestrzeni backupowej dla lokalnych firm.
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 bg-brand-primary text-white text-center">
      <div class="container-custom">
        <h2 class="text-4xl lg:text-7xl font-display font-bold mb-8">Nie czekaj na incydent.</h2>
        <p class="text-xl lg:text-2xl text-white/80 mb-12">Bezpłatny wstępny audyt bezpieczeństwa — zadzwoń i umów wizytę.</p>
        <a href="tel:504365205" class="bg-white text-brand-primary px-12 py-6 rounded-sm font-display font-bold text-2xl inline-flex items-center gap-4 hover:bg-brand-secondary hover:text-white transition-all shadow-2xl">
          → 504 365 205
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
