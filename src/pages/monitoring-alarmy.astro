---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const securityServices = [
  {
    title: 'Monitoring wizyjny CCTV',
    icon: '📹',
    features: ['Projekt i dobór kamer IP/Analog', 'Montaż kamer wewnętrznych i zewnętrznych', 'Konfiguracja podglądu online na smartfonie', 'Integracja z istniejącymi systemami'],
    brands: 'Dahua · Hikvision · IPox · Kenink'
  },
  {
    title: 'Systemy alarmowe',
    icon: '🔔',
    features: ['Montaż central alarmowych', 'Czujniki ruchu, wibracji i otwarcia', 'Powiadomienia SMS i aplikacja mobilna', 'Podłączenie do stacji monitorowania'],
    brands: 'Satel · Jablotron · Ajax'
  },
  {
    title: 'Kontrola dostępu',
    icon: '🔐',
    features: ['Systemy kart i breloków', 'Czytniki biometryczne (odcisk/twarz)', 'Elektroniczne zamki i elektrozaczepy', 'Rejestracja czasu pracy'],
    brands: 'Roger · KaDe · HID'
  }
];

const targetGroups = [
  { title: 'Domy jednorodziny', desc: 'Ochrona mienia i rodziny, monitoring ogrodów i podjazdów.' },
  { title: 'Biura i firmy', desc: 'Ochrona zasobów, kontrola dostępu i rejestracja czasu pracy.' },
  { title: 'Magazyny i hale', desc: 'Monitoring dużych powierzchni, kamery przemysłowe.' },
  { title: 'Instytucje', desc: 'Kompleksowe systemy bezpieczeństwa dla obiektów publicznych.' }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Monitoring i Systemy Alarmowe",
  "description": "Profesjonalny montaż kamer CCTV, alarmów i kontroli dostępu w Tarnowie i Małopolsce. Bezpłatna wycena i projekt systemu.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Centre Service IT",
    "url": "https://csi-tarnow.pl"
  },
  "areaServed": {
    "@type": "State",
    "name": "Małopolska"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Systemy bezpieczeństwa",
    "itemListElement": securityServices.map(s => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": s.title
      }
    }))
  }
};
---

<Layout 
  title="Monitoring i Systemy Alarmowe | Tarnów" 
  description="Profesjonalny montaż kamer CCTV, alarmów i kontroli dostępu w Tarnowie i Małopolsce. Bezpłatna wycena i projekt systemu. Tel: 504 365 205."
  breadcrumbs={[
    { name: "Usługi", item: "/#uslugi" },
    { name: "Monitoring & Alarmy", item: "/monitoring-alarmy" }
  ]}
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(serviceSchema)} />
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO -->
    <header class="py-16 lg:py-40 bg-slate-50 relative border-b border-slate-100">
      <div class="container-custom relative z-10">
        <span class="technical-label with-cursor mb-6 block">Kamery CCTV · Systemy alarmowe · Kontrola dostępu</span>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-display font-black text-slate-900 leading-[0.95] tracking-tighter mb-8 max-w-5xl">
          Bezpieczeństwo Twojego domu i firmy — <span class="text-brand-primary">w naszych rękach.</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-500 max-w-2xl mb-12 leading-relaxed">
          Projektujemy, instalujemy i serwisujemy profesjonalne systemy bezpieczeństwa dla domów, firm i instytucji w całej Małopolsce.
        </p>
        <div class="flex flex-col sm:flex-row gap-6">
          <a href="tel:504365205" class="bg-brand-primary text-white px-8 lg:px-10 py-4 lg:py-5 rounded-sm font-display font-bold text-base lg:text-lg inline-flex items-center justify-center gap-4 hover:bg-brand-secondary transition-all shadow-xl">
            → Zamów bezpłatną wycenę
          </a>
        </div>
      </div>
      <!-- Decorative element -->
      <div class="absolute bottom-0 right-0 w-1/2 h-full bg-white/50 -skew-x-12 translate-x-1/4 pointer-events-none"></div>
    </header>

    <!-- SERVICES -->
    <section class="py-32 bg-white">
      <div class="container-custom">
        <div class="mb-12 lg:mb-20">
          <span class="technical-label with-cursor mb-4 block">Nasze usługi</span>
          <h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary max-w-4xl">Kompleksowe rozwiązania bezpieczeństwa</h2>
        </div>

        <div class="space-y-8 lg:space-y-12">
          {securityServices.map((service, index) => (
            <div class={`flex flex-col lg:flex-row gap-8 lg:gap-12 p-8 lg:p-12 border border-slate-200 hover:border-brand-primary transition-colors ${index % 2 === 1 ? 'lg:flex-row-reverse bg-slate-50' : ''}`}>
              <div class="lg:w-1/3">
                <div class="text-5xl lg:text-6xl mb-6 lg:mb-8">{service.icon}</div>
                <h3 class="text-2xl lg:text-3xl font-display font-bold text-brand-secondary mb-4 lg:mb-6">{service.title}</h3>
                <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">{service.brands}</p>
              </div>
              <div class="lg:w-2/3 grid sm:grid-cols-2 gap-8">
                {service.features.map(f => (
                  <div class="flex items-start gap-4 p-5 lg:p-6 bg-white border border-slate-100 shadow-sm">
                    <span class="w-1.5 h-1.5 lg:w-2 lg:h-2 bg-brand-primary rounded-full mt-2 flex-shrink-0"></span>
                    <p class="text-slate-700 font-medium text-sm lg:text-base leading-relaxed">{f}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TARGET GROUPS -->
    <section class="section-padding bg-brand-secondary text-white">
      <div class="container-custom">
        <div class="text-center mb-20">
          <span class="technical-label with-cursor text-brand-primary mb-4 block">Dla kogo projektujemy?</span>
          <h2 class="text-4xl lg:text-6xl font-display font-bold">Ochrona dopasowana do potrzeb</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          {targetGroups.map(group => (
            <div class="p-8 lg:p-10 border border-white/10 bg-white/5 hover:bg-white/10 transition-colors">
              <h3 class="text-lg lg:text-xl font-display font-bold mb-4">{group.title}</h3>
              <p class="text-white/70 text-xs lg:text-sm leading-relaxed">{group.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="py-32 bg-white">
      <div class="container-custom">
        <div class="mb-16 lg:mb-20 text-center lg:text-left">
          <span class="technical-label with-cursor mb-4 block">Od projektu do montażu</span>
          <h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary">Jak powstaje Twój system?</h2>
        </div>
        <div class="grid md:grid-cols-3 lg:grid-cols-5 gap-8">
          {[
            { step: '01', title: 'Konsultacja', desc: 'Przyjeżdżamy na miejsce, oceniamy potrzeby i proponujemy rozwiązanie.' },
            { step: '02', title: 'Projekt', desc: 'Przygotowujemy plan rozmieszczenia kamer i czujników.' },
            { step: '03', title: 'Montaż', desc: 'Instalujemy system sprawnie i bez zakłóceń.' },
            { step: '04', title: 'Konfiguracja', desc: 'Uruchamiamy podgląd mobilny i szkolimy z obsługi.' },
            { step: '05', title: 'Serwis', desc: 'Zapewniamy stałą opiekę i konserwację instalacji.' }
          ].map(s => (
            <div class="relative">
              <span class="font-mono text-[64px] font-black text-slate-100 absolute -top-10 -left-2 z-0 leading-none">{s.step}</span>
              <div class="relative z-10 pt-4">
                <h3 class="text-xl font-display font-bold text-brand-secondary mb-4">{s.title}</h3>
                <p class="text-slate-600 text-sm leading-relaxed">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding bg-brand-primary text-white text-center">
      <div class="container-custom">
        <h2 class="text-3xl lg:text-7xl font-display font-bold mb-8">Zabezpiecz swoją przestrzeń<br/>zanim będzie za późno.</h2>
        <p class="text-lg lg:text-2xl text-white/80 mb-12">Bezpłatna wycena na miejscu — bez zobowiązań.</p>
        <a href="tel:504365205" class="bg-white text-brand-primary px-8 lg:px-12 py-5 lg:py-6 rounded-sm font-display font-bold text-xl lg:text-2xl inline-flex items-center gap-4 hover:bg-brand-secondary hover:text-white transition-all shadow-2xl">
          → 504 365 205
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
