---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Serwis Elektroniki',
    description: "Naprawiamy iPhone'y, MacBooki, laptopy, tablety i konsole. Szybko. Z gwarancją.",
    href: '/serwis-elektroniki',
    id: '01'
  },
  {
    title: 'Odzyskiwanie Danych',
    description: 'Uszkodzony dysk, pendrive lub karta pamięci? Odzyskujemy pliki, które inni uznają za stracone.',
    href: '/odzyskiwanie-danych',
    id: '02'
  },
  {
    title: 'Monitoring & Alarmy',
    description: 'Profesjonalny montaż kamer CCTV, systemów alarmowych i kontroli dostępu dla domu i firmy.',
    href: '/monitoring-alarmy',
    id: '03'
  },
  {
    title: 'Automatyka & Smart Home',
    description: 'Bramy wjazdowe, segmentowe, inteligentne domy — montaż, konfiguracja i serwis.',
    href: '/automatyka-smart-home',
    id: '04'
  },
  {
    title: 'Cyberbezpieczeństwo',
    description: 'Chroń swoją firmę przed hakerami, phishingiem i ransomware. Zabezpieczamy sieci i systemy IT.',
    href: '/cyberbezpieczenstwo',
    id: '05'
  },
  {
    title: 'Usługi IT & Technologia',
    description: 'Strony internetowe, druk 3D, serwisy NAS i chmury, serwis drukarek — kompleksowe wsparcie.',
    href: '/uslugi-it-technologia',
    id: '06'
  }
];

const features = [
  {
    title: 'Ekspresowa realizacja',
    desc: 'Diagnostyka w tym samym dniu. Większość napraw gotowa w 24–48 godzin. Bez zbędnego czekania.'
  },
  {
    title: 'Gwarancja jakości',
    desc: 'Na każdą naprawę udzielamy gwarancji. Jeśli coś pójdzie nie tak — wracamy do sprawy bezpłatnie.'
  },
  {
    title: 'Lokalnie, dla Małopolski',
    desc: 'Obsługujemy Tarnów i okolicę. Wiemy, czego potrzebują lokalne firmy i mieszkańcy.'
  },
  {
    title: 'Pełne doradztwo',
    desc: 'Nie wciskamy zbędnych usług. Diagnozujemy, doradzamy i proponujemy najbardziej opłacalne rozwiązanie.'
  }
];
---

<Layout title="Serwis Elektroniki, Odzyskiwanie Danych, Monitoring">
	<Navbar />
	
	<main class="pt-20">
		<!-- HERO SECTION -->
		<section class="relative overflow-hidden pt-20 pb-32 lg:pt-32 lg:pb-48">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(0,71,255,0.05),transparent_50%)]"></div>
			<div class="container-custom relative">
				<div class="max-w-4xl">
					<span class="technical-label mb-6 block" data-astro-reveal>Tarnów i Małopolska — lokalnie, szybko, z gwarancją</span>
					<h1 class="text-5xl lg:text-8xl font-display font-bold leading-[0.9] text-brand-secondary mb-8">
						Twoja elektronika znowu działa. <span class="text-brand-primary">Twoje dane są bezpieczne.</span> Twoja firma jest chroniona.
					</h1>
					<p class="text-xl lg:text-2xl text-slate-600 mb-12 max-w-2xl leading-relaxed">
						Centre Service IT to kompleksowy serwis elektroniki, odzyskiwanie danych i profesjonalne systemy bezpieczeństwa dla klientów w Tarnowie i całej Małopolsce.
					</p>
					<div class="flex flex-col sm:flex-row gap-6">
						<a href="tel:504365205" class="group bg-brand-primary text-white px-8 py-5 rounded-sm font-display font-bold text-lg inline-flex items-center justify-center gap-3 hover:bg-brand-secondary transition-all shadow-xl shadow-brand-primary/20">
							→ Zadzwoń teraz: 504 365 205
						</a>
						<a href="#uslugi" class="px-8 py-5 rounded-sm font-display font-bold text-lg inline-flex items-center justify-center gap-3 border-2 border-slate-200 text-brand-secondary hover:border-brand-primary transition-all">
							→ Zobacz nasze usługi
						</a>
					</div>
				</div>

				<!-- Trust Bar -->
				<div class="mt-24 pt-12 border-t border-slate-200 flex flex-wrap gap-x-12 gap-y-6">
					{['Ekspresowa diagnostyka', 'Gwarancja na naprawy', 'Ponad 10 lat doświadczenia', 'Obsługa firm i osób prywatnych'].map(text => (
						<div class="flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-slate-500">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary"><polyline points="20 6 9 17 4 12"></polyline></svg>
							{text}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- SERVICES SECTION -->
		<section id="uslugi" class="py-32 bg-slate-50">
			<div class="container-custom">
				<div class="mb-20">
					<span class="technical-label mb-4 block">Co robimy</span>
					<h2 class="text-4xl lg:text-6xl font-display font-bold text-brand-secondary mb-6 leading-tight">
						Jeden serwis.<br/>Wszystkie problemy techniczne.
					</h2>
					<p class="text-xl text-slate-600 max-w-2xl leading-relaxed">
						Nie musisz szukać kilku specjalistów — zajmujemy się wszystkim, czego potrzebuje Twój sprzęt, Twoje dane i Twoja sieć.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-slate-200 border border-slate-200 overflow-hidden shadow-2xl">
					{services.map(service => (
						<a href={service.href} class="group bg-white p-12 hover:bg-brand-primary transition-all duration-500 flex flex-col justify-between min-h-[400px]">
							<div>
								<span class="font-mono text-sm text-slate-400 group-hover:text-white/60 mb-8 block">{service.id}</span>
								<h3 class="text-2xl lg:text-3xl font-display font-bold text-brand-secondary group-hover:text-white mb-6 leading-tight">{service.title}</h3>
								<p class="text-slate-600 group-hover:text-white/80 leading-relaxed">{service.description}</p>
							</div>
							<div class="mt-12 flex items-center gap-3 text-brand-primary group-hover:text-white font-display font-bold uppercase tracking-wider text-sm transition-all group-hover:translate-x-2">
								Dowiedz się więcej →
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- WHY US SECTION -->
		<section class="py-32 overflow-hidden">
			<div class="container-custom">
				<div class="grid lg:grid-cols-2 gap-24 items-center">
					<div>
						<span class="technical-label mb-4 block">Dlaczego Centre Service IT?</span>
						<h2 class="text-4xl lg:text-6xl font-display font-bold text-brand-secondary mb-8 leading-[1.1]">
							Nie naprawiamy sprzętu na odległość. <span class="text-brand-primary">Jesteśmy obok.</span>
						</h2>
						<p class="text-xl text-slate-600 mb-12 leading-relaxed">
							Lokalni, dostępni i zaangażowani — to nas wyróżnia na tle dużych sieciowych serwisów.
						</p>
						<div class="grid sm:grid-cols-2 gap-10">
							{features.map(f => (
								<div>
									<h4 class="font-display font-bold text-lg text-brand-secondary mb-3">{f.title}</h4>
									<p class="text-slate-600 text-sm leading-relaxed">{f.desc}</p>
								</div>
							))}
						</div>
					</div>
					<div class="relative">
						<div class="aspect-square bg-slate-100 rounded-sm overflow-hidden border border-slate-200 relative group">
              <div class="absolute inset-0 bg-brand-primary/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[200px] font-display font-black text-slate-200/50 select-none">CS</div>
            </div>
            <!-- Technical floating box -->
            <div class="absolute -bottom-10 -left-10 bg-white p-8 shadow-2xl border border-slate-100 max-w-xs">
              <span class="technical-label text-[8px] mb-2 block">Status: Aktywny</span>
              <p class="text-brand-secondary font-display font-bold leading-tight">
                Ponad 10 000 naprawionych urządzeń w Tarnowie.
              </p>
            </div>
					</div>
				</div>
			</div>
		</section>

		<!-- SOCIAL PROOF -->
		<section class="py-32 bg-brand-secondary text-white">
			<div class="container-custom text-center mb-20">
				<span class="technical-label text-brand-primary mb-4 block">Opinie klientów</span>
				<h2 class="text-4xl lg:text-6xl font-display font-bold mb-6">Co mówią o nas nasi klienci?</h2>
			</div>
			<div class="container-custom">
				<div class="grid lg:grid-cols-3 gap-8">
					{[
						{ text: "Szybka i profesjonalna obsługa. Laptop naprawiony następnego dnia, dane odzyskane w całości. Polecam serdecznie!", author: "Klient indywidualny, Tarnów" },
						{ text: "Montaż monitoringu w firmie przebiegł sprawnie i bez zakłóceń w pracy. Ekipa solidna, ceny uczciwe.", author: "Właściciel firmy, Małopolska" },
						{ text: "Myślałem, że dane z pendrive'a są stracone na zawsze. Centre Service IT odzyskało wszystko. Niesamowita robota!", author: "Klient indywidualny" }
					].map(testimonial => (
						<div class="bg-white/5 p-10 border border-white/10 relative">
							<svg class="text-brand-primary mb-6" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017V14H17.017C15.9124 14 15.017 13.1046 15.017 12V9C15.017 7.89543 15.9124 7 17.017 7H20.017C21.1216 7 22.017 7.89543 22.017 9V12C22.017 13.1046 21.1216 14 20.017 14V16C21.1216 16 22.017 16.8954 22.017 18V21H14.017ZM2.01697 21L2.01697 18C2.01697 16.8954 2.9124 16 4.01697 16H7.01697V14H5.01697C3.9124 14 3.01697 13.1046 3.01697 12V9C3.01697 7.89543 3.9124 7 5.01697 7H8.01697C9.12154 7 10.017 7.89543 10.017 9V12C10.017 13.1046 9.12154 14 8.01697 14V16C9.12154 16 10.017 16.8954 10.017 18V21H2.01697Z"></path></svg>
							<p class="text-xl text-white/90 mb-8 italic leading-relaxed">"{testimonial.text}"</p>
							<span class="technical-label text-brand-primary text-[10px]">{testimonial.author}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- LOCAL COVERAGE -->
		<section class="py-32">
			<div class="container-custom">
				<div class="bg-slate-50 border border-slate-200 p-12 lg:p-24 flex flex-col lg:flex-row items-center gap-16">
					<div class="flex-1 text-center lg:text-left">
						<span class="technical-label mb-4 block">Nasz zasięg</span>
						<h2 class="text-4xl lg:text-6xl font-display font-bold text-brand-secondary mb-6">Działamy w Tarnowie i całej Małopolsce</h2>
						<p class="text-xl text-slate-600 mb-0 leading-relaxed">
							Obsługujemy klientów z Tarnowa, Krakowa, Bochni, Brzeska i okolic. Wyjeżdżamy do klientów — zapytaj o wycenę wizyty.
						</p>
					</div>
					<div class="flex-shrink-0 w-full lg:w-auto bg-white p-10 shadow-xl border border-slate-100">
						<div class="space-y-6">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-slate-50 flex items-center justify-center text-brand-primary rounded-sm border border-slate-200">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
								</div>
								<div>
									<span class="technical-label text-[8px] text-slate-400 block mb-1">Kontakt telefoniczny</span>
									<span class="font-display font-bold text-xl text-brand-secondary">504 365 205</span>
								</div>
							</div>
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-slate-50 flex items-center justify-center text-brand-primary rounded-sm border border-slate-200">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
								</div>
								<div>
									<span class="technical-label text-[8px] text-slate-400 block mb-1">Lokalizacja</span>
									<span class="font-display font-bold text-xl text-brand-secondary">Tarnów, Małopolska</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA BANNER -->
		<section class="py-32 bg-brand-primary text-white text-center">
			<div class="container-custom">
				<h2 class="text-4xl lg:text-7xl font-display font-bold mb-6">Masz problem z elektroniką lub danymi?</h2>
				<p class="text-xl lg:text-2xl mb-12 opacity-90 font-medium">Nie trać czasu na szukanie. Zadzwoń teraz — pierwsza diagnostyka bezpłatna.</p>
				<a href="tel:504365205" class="bg-white text-brand-primary px-12 py-6 rounded-sm font-display font-bold text-2xl inline-flex items-center gap-4 hover:bg-brand-secondary hover:text-white transition-all shadow-2xl">
					→ Zadzwoń: 504 365 205
				</a>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
