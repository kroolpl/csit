---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import csitWorkshop from '../assets/images/csit_workshop.webp';
import tarnowMap from '../assets/images/tarnow_map_bg.png';

const services = [
  {
    title: 'Serwis Elektroniki',
    description: "Naprawiamy iPhone'y, MacBooki, laptopy, tablety i konsole. Szybko. Z gwarancją.",
    href: '/serwis-elektroniki',
    id: '01',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/><path d="M9 7l3 3-3 3"/></svg>`
  },
  {
    title: 'Odzykiwanie Danych',
    description: 'Uszkodzony dysk, pendrive lub karta pamięci? Odzyskujemy pliki, które inni uznają za stracone.',
    href: '/odzyskiwanie-danych',
    id: '02',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`
  },
  {
    title: 'Monitoring & Alarmy',
    description: 'Profesjonalny montaż kamer CCTV, systemów alarmowych i kontroli dostępu dla domu i firmy.',
    href: '/monitoring-alarmy',
    id: '03',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`
  },
  {
    title: 'Automatyka & Smart Home',
    description: 'Bramy wjazdowe, segmentowe, inteligentne domy — montaż, konfiguracja i serwis.',
    href: '/automatyka-smart-home',
    id: '04',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`
  },
  {
    title: 'Cyberbezpieczeństwo',
    description: 'Chroń swoją firmę przed hakerami, phishingiem i ransomware. Zabezpieczamy sieci i systemy IT.',
    href: '/cyberbezpieczenstwo',
    id: '05',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  {
    title: 'Usługi IT & Technologia',
    description: 'Strony internetowe, druk 3D, serwisy NAS i chmury, serwis drukarek — kompleksowe wsparcie.',
    href: '/uslugi-it-technologia',
    id: '06',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>`
  }
];

const features = [
  {
    title: 'Ekspresowa realizacja',
    desc: 'Diagnostyka w tym samym dniu. Większość napraw gotowa w 24–48 godzin. Bez zbędnego czekania.'
  },
  {
    title: 'Gwarancja jakości',
    desc: 'Na każdą naprawę udzielamy gwarancji. Jeśli coś pójdzie nie tak — wracamy do sprawy bezpłatnie.'
  },
  {
    title: 'Lokalnie, dla Małopolski',
    desc: 'Obsługujemy Tarnów i okolicę. Wiemy, czego potrzebują lokalne firmy i mieszkańcy.'
  },
  {
    title: 'Pełne doradztwo',
    desc: 'Nie wciskamy zbędnych usług. Diagnozujemy, doradzamy i proponujemy najbardziej opłacalne rozwiązanie.'
  }
];
---

<Layout title="Serwis Elektroniki, Odzyskiwanie Danych, Monitoring">
	<Navbar />
	
	<main class="pt-20">
		<!-- HERO SECTION -->
		<section class="relative bg-slate-50 pt-24 pb-32 lg:pt-32 lg:pb-40 border-b border-slate-200 overflow-hidden">
      <!-- Subtle background grid -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#0047ff 1px, transparent 1px), linear-gradient(90deg, #0047ff 1px, transparent 1px); background-size: 32px 32px;"></div>

      <div class="container-custom relative z-10">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
          
          <!-- Text Content (Left, span 7) -->
          <div class="lg:col-span-7">
            <span class="technical-label with-cursor mb-6 block">Tarnów i Małopolska</span>
            
            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-display font-black text-slate-900 leading-[1.1] mb-8 tracking-tight">
              Profesjonalne IT.<br/>
              <span class="text-brand-primary">Bez kompromisów.</span>
            </h1>
            
            <p class="text-lg lg:text-xl text-slate-600 mb-10 max-w-2xl leading-relaxed">
              Zapewniamy ciągłość działania Twojej firmy i spokój w domu. Od błyskawicznej naprawy elektroniki, przez odzyskiwanie danych, po zaawansowane systemy bezpieczeństwa.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-16">
              <a href="tel:504365205" class="bg-brand-primary text-white px-8 py-4 rounded-sm font-display font-bold text-base flex items-center justify-center gap-3 hover:bg-brand-secondary transition-colors shadow-xl shadow-brand-primary/20">
                → Zadzwoń: 504 365 205
              </a>
              <a href="#uslugi" class="bg-white text-slate-900 border-2 border-slate-200 px-8 py-4 rounded-sm font-display font-bold text-base flex items-center justify-center gap-3 hover:border-brand-primary hover:text-brand-primary transition-colors">
                Zobacz ofertę
              </a>
            </div>

            <!-- The 3 Promises -->
            <div class="flex flex-wrap justify-center lg:justify-start gap-x-8 gap-y-6 lg:gap-x-12">
              <div class="flex items-center gap-3">
                <div class="shrink-0 bg-brand-primary/10 p-1.5 rounded-full text-brand-primary">
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <span class="text-xs sm:text-sm font-bold text-slate-900 leading-tight">Sprawna elektronika</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="shrink-0 bg-brand-primary/10 p-1.5 rounded-full text-brand-primary">
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <span class="text-xs sm:text-sm font-bold text-slate-900 leading-tight">Bezpieczne dane</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="shrink-0 bg-brand-primary/10 p-1.5 rounded-full text-brand-primary">
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <span class="text-xs sm:text-sm font-bold text-slate-900 leading-tight">Chroniona firma</span>
              </div>
            </div>
          </div>

          <!-- Visual Content (Right, span 5) -->
          <div class="lg:col-span-5 relative hidden lg:block">
            <!-- A clean, abstract technical visual -->
            <div class="relative bg-white rounded-2xl p-8 lg:p-10 border border-slate-200 shadow-2xl overflow-hidden aspect-square flex flex-col justify-between group hover:shadow-brand-primary/10 transition-shadow duration-500">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(0,71,255,0.05),transparent_60%)] pointer-events-none transition-opacity duration-500 group-hover:opacity-100 opacity-50"></div>
                
                <div class="flex justify-between items-start relative z-10">
                  <div class="w-14 h-14 bg-brand-primary/10 rounded-2xl flex items-center justify-center text-brand-primary">
                     <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
                  </div>
                  <div class="flex items-center gap-2 bg-emerald-50 text-emerald-600 px-3 py-1.5 rounded-full border border-emerald-100">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="technical-label !text-emerald-600 !tracking-widest !text-[8px] m-0 leading-none">System Active</span>
                  </div>
                </div>

                <div class="relative z-10 mt-auto">
                  <div class="flex items-end gap-3 mb-2">
                    <h3 class="font-display font-black text-5xl lg:text-7xl text-slate-900 leading-none tracking-tighter">99.9<span class="text-brand-primary text-3xl">%</span></h3>
                  </div>
                  <p class="font-mono text-[10px] text-slate-500 uppercase tracking-[0.2em] font-bold">Skuteczności usług</p>
                </div>
                
                <!-- decorative technical lines -->
                <div class="absolute bottom-0 right-0 w-2/3 h-2/3 opacity-30 pointer-events-none" style="background-image: repeating-linear-gradient(45deg, #0047ff 0, #0047ff 1px, transparent 0, transparent 40%); background-size: 8px 8px;"></div>
            </div>
          </div>

        </div>
      </div>
    </section>


		<!-- SERVICES SECTION -->
		<section id="uslugi" class="section-padding bg-slate-50">
			<div class="container-custom">
				<div class="mb-12 lg:mb-20">
					<span class="technical-label with-cursor mb-4 block">Co robimy</span>
					<h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary mb-6 leading-tight">
						Jeden serwis.<br/>Wszystkie problemy techniczne.
					</h2>
					<p class="text-lg lg:text-xl text-slate-600 max-w-2xl leading-relaxed">
						Nie musisz szukać kilku specjalistów — zajmujemy się wszystkim, czego potrzebuje Twój sprzęt, Twoje dane i Twoja sieć.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-slate-200 border border-slate-200 overflow-hidden shadow-2xl">
					{services.map(service => (
						<a href={service.href} class="group bg-white p-8 lg:p-10 hover:bg-brand-secondary transition-all duration-500 flex flex-col justify-between min-h-[280px] lg:min-h-[360px]">
							<div>
								<!-- Icon + number row -->
								<div class="flex items-center justify-between mb-6 lg:mb-8">
									<div class="w-12 h-12 bg-brand-primary/10 group-hover:bg-brand-primary/20 flex items-center justify-center text-brand-primary transition-colors" set:html={service.icon} />
									<span class="font-mono text-xs text-slate-400 group-hover:text-white/60">{service.id}</span>
								</div>
								<h3 class="text-xl lg:text-2xl font-display font-bold text-brand-secondary group-hover:text-white mb-3 lg:mb-4 leading-tight">{service.title}</h3>
								<p class="text-sm text-slate-500 group-hover:text-white/70 leading-relaxed">{service.description}</p>
							</div>
							<div class="mt-6 lg:mt-8 flex items-center gap-2 text-brand-primary group-hover:text-white font-display font-bold uppercase tracking-wider text-xs transition-all group-hover:translate-x-2">
								Dowiedz się więcej →
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- WHY US SECTION -->
		<section class="section-padding overflow-hidden">
			<div class="container-custom">
				<div class="grid lg:grid-cols-2 gap-24 items-center">
					<div>
						<span class="technical-label with-cursor mb-4 block">Dlaczego Centre Service IT?</span>
						<h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary mb-6 lg:mb-8 leading-tight lg:leading-[1.1]">
							Nie naprawiamy sprzętu na odległość. <span class="text-brand-primary">Jesteśmy obok.</span>
						</h2>
						<p class="text-xl text-slate-600 mb-12 leading-relaxed">
							Lokalni, dostępni i zaangażowani — to nas wyróżnia na tle dużych sieciowych serwisów.
						</p>
						<div class="grid sm:grid-cols-2 gap-6 lg:gap-8">
							{features.map(f => (
								<div class="p-5 border border-slate-100 bg-slate-50 hover:border-brand-primary hover:bg-white transition-all group">
									<div class="w-2 h-2 bg-brand-primary rounded-full mb-4"></div>
									<h3 class="font-display font-bold text-base text-brand-secondary mb-2 group-hover:text-brand-primary transition-colors">{f.title}</h3>
									<p class="text-slate-600 text-sm leading-relaxed">{f.desc}</p>
								</div>
							))}
						</div>
					</div>
					<div class="relative mt-12 lg:mt-0">
						<div class="rounded-sm overflow-hidden border border-slate-200 shadow-2xl relative">
              <Image src={csitWorkshop} alt="Serwis Centre Service IT - warsztat" class="w-full h-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-secondary/60 via-transparent to-transparent"></div>
            </div>
            <!-- Floating stat box -->
            <div class="absolute bottom-0 left-0 lg:-bottom-8 lg:-left-8 bg-white/95 backdrop-blur-sm p-4 lg:p-6 shadow-2xl border-l-4 border-brand-primary max-w-[200px] lg:max-w-xs">
              <span class="technical-label text-[7px] lg:text-[8px] text-slate-500 mb-1 block">Zaufało nam</span>
              <p class="text-brand-secondary font-display font-bold text-sm lg:text-lg leading-tight">
                Ponad <span class="text-brand-primary">10 000</span> zadowolonych klientów.
              </p>
            </div>
					</div>
				</div>
			</div>
		</section>

		<!-- SOCIAL PROOF -->
		<section class="section-padding bg-brand-secondary text-white">
			<div class="container-custom text-center mb-16 lg:mb-20">
				<span class="technical-label with-cursor text-white/80 mb-4 block">Opinie klientów</span>
				<h2 class="text-3xl lg:text-6xl font-display font-bold mb-6">Co mówią o nas nasi klienci?</h2>
			</div>
			<div class="container-custom">
				<div class="grid lg:grid-cols-3 gap-8">
					{[
						{ text: "Szybka i profesjonalna obsługa. Laptop naprawiony następnego dnia, dane odzyskane w całości. Polecam serdecznie!", author: "Klient indywidualny, Tarnów" },
						{ text: "Montaż monitoringu w firmie przebiegł sprawnie i bez zakłóceń w pracy. Ekipa solidna, ceny uczciwe.", author: "Właściciel firmy, Małopolska" },
						{ text: "Myślałem, że dane z pendrive'a są stracone na zawsze. Centre Service IT odzyskało wszystko. Niesamowita robota!", author: "Klient indywidualny" }
					].map(testimonial => (
						<div class="bg-white/5 p-8 lg:p-10 border border-white/10 relative group hover:border-brand-primary/50 transition-colors">
							<div class="flex justify-between items-start mb-6 lg:mb-8">
								<svg class="text-brand-primary" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017V14H17.017C15.9124 14 15.017 13.1046 15.017 12V9C15.017 7.89543 15.9124 7 17.017 7H20.017C21.1216 7 22.017 7.89543 22.017 9V12C22.017 13.1046 21.1216 14 20.017 14V16C21.1216 16 22.017 16.8954 22.017 18V21H14.017ZM2.01697 21L2.01697 18C2.01697 16.8954 2.9124 16 4.01697 16H7.01697V14H5.01697C3.9124 14 3.01697 13.1046 3.01697 12V9C3.01697 7.89543 3.9124 7 5.01697 7H8.01697C9.12154 7 10.017 7.89543 10.017 9V12C10.017 13.1046 9.12154 14 8.01697 14V16C9.12154 16 10.017 16.8954 10.017 18V21H2.01697Z"></path></svg>
								<div class="flex gap-1">
									{[...Array(5)].map(() => (
										<svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
									))}
								</div>
							</div>
							<p class="text-lg lg:text-xl text-white/90 mb-6 lg:mb-8 italic leading-relaxed">"{testimonial.text}"</p>
							<span class="technical-label text-white/70 text-[10px]">{testimonial.author}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- LOCAL COVERAGE -->
		<section class="section-padding">
			<div class="container-custom">
				<div class="bg-slate-50 border border-slate-200 p-8 lg:p-24 flex flex-col lg:flex-row items-center gap-12 lg:gap-16 relative overflow-hidden group">
          <!-- Stylized Map Background -->
          <div class="absolute inset-0 opacity-[0.12] pointer-events-none group-hover:opacity-[0.18] transition-opacity duration-700">
            <Image src={tarnowMap} alt="" class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-transform duration-[20s] ease-linear" />
          </div>
					<div class="flex-1 text-center lg:text-left">
						<span class="technical-label with-cursor mb-4 block">Nasz zasięg</span>
						<h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary mb-6 leading-tight">Działamy w Tarnowie i całej Małopolsce</h2>
						<p class="text-lg lg:text-xl text-slate-600 mb-0 leading-relaxed">
							Obsługujemy klientów z Tarnowa, Krakowa, Bochni, Brzeska i okolic. Wyjeżdżamy do klientów — zapytaj o wycenę wizyty.
						</p>
					</div>
					<div class="flex-shrink-0 w-full lg:w-auto bg-white p-10 shadow-xl border border-slate-100">
						<div class="space-y-6">
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-slate-50 flex items-center justify-center text-brand-primary rounded-sm border border-slate-200">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
								</div>
								<div>
									<span class="technical-label text-[8px] text-slate-500 block mb-1">Kontakt telefoniczny</span>
									<span class="font-display font-bold text-xl text-brand-secondary">504 365 205</span>
								</div>
							</div>
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 bg-slate-50 flex items-center justify-center text-brand-primary rounded-sm border border-slate-200">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
								</div>
								<div>
									<span class="technical-label text-[8px] text-slate-500 block mb-1">Lokalizacja</span>
									<span class="font-display font-bold text-xl text-brand-secondary">Tarnów, Małopolska</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA BANNER -->
		<section class="section-padding bg-brand-primary text-white text-center">
			<div class="container-custom">
				<h2 class="text-3xl lg:text-7xl font-display font-bold mb-6">Masz problem z elektroniką lub danymi?</h2>
				<p class="text-lg lg:text-2xl mb-12 opacity-90 font-medium">Nie trać czasu na szukanie. Zadzwoń teraz — pierwsza diagnostyka bezpłatna.</p>
				<a href="tel:504365205" class="bg-white text-brand-primary px-8 lg:px-12 py-5 lg:py-6 rounded-sm font-display font-bold text-xl lg:text-2xl inline-flex items-center gap-4 hover:bg-brand-secondary hover:text-white transition-all shadow-2xl">
					→ Zadzwoń: 504 365 205
				</a>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
