---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const contactMethods = [
  {
    title: 'Zadzwoń do nas',
    value: '504 365 205',
    sub: 'Pn – Pt: 09:00 – 18:00',
    href: 'tel:504365205',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  },
  {
    title: 'Napisz e-mail',
    value: 'biuro@csi-tarnow.pl',
    sub: 'Odpowiadamy w ciągu kilku godzin',
    href: 'mailto:biuro@csi-tarnow.pl',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/><rect width="20" height="14" x="2" y="5" rx="2"/></svg>`
  },
  {
    title: 'Odwiedź nas',
    value: 'Tarnów, Małopolska',
    sub: 'Zapraszamy z urządzeniem do serwisu',
    href: '#mapa',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`
  }
];
---

<Layout 
  title="Kontakt | Centre Service IT Tarnów" 
  description="Skontaktuj się z profesjonalnym serwisem IT w Tarnowie. Bezpłatna wycena i doradztwo techniczne."
>
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO -->
    <section class="bg-white py-16 lg:py-32 border-b border-slate-100">
      <div class="container-custom">
        <span class="technical-label with-cursor mb-6 block">Kontakt i Wsparcie</span>
        <h1 class="text-4xl lg:text-7xl font-display font-black text-brand-secondary leading-tight mb-8">
          Twoja technologia, <br/> <span class="text-brand-primary">nasza odpowiedzialność.</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-600 max-w-3xl leading-relaxed">
          Masz pytanie dotyczące naprawy urządzenia lub montażu systemu bezpieczeństwa? Jesteśmy do Twojej dyspozycji. Skontaktuj się z nami telefonicznie, mailowo lub odwiedź nas osobiście w Tarnowie.
        </p>
      </div>
    </section>

    <!-- CONTACT CARDS -->
    <section class="py-12 bg-slate-50 border-b border-slate-200">
      <div class="container-custom">
        <div class="grid md:grid-cols-3 gap-8">
          {contactMethods.map(item => (
            <a href={item.href} class="bg-white p-10 border border-slate-200 shadow-sm hover:shadow-xl hover:border-brand-primary transition-all group">
              <div class="w-14 h-14 bg-slate-50 flex items-center justify-center text-brand-primary mb-8 group-hover:bg-brand-primary group-hover:text-white transition-colors">
                <div set:html={item.icon} />
              </div>
              <h2 class="font-display font-bold text-xl text-brand-secondary mb-2">{item.title}</h2>
              <p class="font-display font-black text-2xl text-brand-secondary group-hover:text-brand-primary transition-colors mb-2 tracking-tight">{item.value}</p>
              <p class="text-sm text-slate-500">{item.sub}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FORM & MAP SECTION -->
    <section id="mapa" class="py-16 lg:py-32 bg-white">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
          
          <!-- Contact Form -->
          <div class="bg-slate-50 p-8 lg:p-12 border border-slate-200 rounded-sm">
            <h2 class="text-3xl lg:text-5xl font-display font-black text-brand-secondary mb-6 tracking-tight">Wyślij wiadomość</h2>
            <p class="text-slate-600 mb-10">Opisz swój problem techniczny, a my wrócimy do Ciebie z propozycją rozwiązania i wyceną.</p>
            
            <form class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="font-mono text-[10px] uppercase text-slate-500 font-bold tracking-widest">Imię i nazwisko</label>
                  <input type="text" placeholder="Jan Kowalski" class="w-full bg-white border border-slate-200 p-4 focus:outline-none focus:border-brand-primary transition-colors text-sm" required />
                </div>
                <div class="space-y-2">
                  <label class="font-mono text-[10px] uppercase text-slate-500 font-bold tracking-widest">Telefon lub e-mail</label>
                  <input type="text" placeholder="504 365 205" class="w-full bg-white border border-slate-200 p-4 focus:outline-none focus:border-brand-primary transition-colors text-sm" required />
                </div>
              </div>
              <div class="space-y-2">
                <label class="font-mono text-[10px] uppercase text-slate-500 font-bold tracking-widest">W czym możemy pomóc?</label>
                <textarea rows="5" placeholder="Opisz usterkę lub zapytaj o usługę..." class="w-full bg-white border border-slate-200 p-4 focus:outline-none focus:border-brand-primary transition-colors text-sm resize-none" required></textarea>
              </div>
              <button type="submit" class="w-full bg-brand-primary text-white py-5 rounded-sm font-display font-bold text-lg hover:bg-brand-secondary transition-all shadow-xl shadow-brand-primary/20">
                Wyślij zapytanie →
              </button>
            </form>
          </div>

          <!-- Map & Directions -->
          <div class="relative group">
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-brand-primary/5 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
            
            <div class="relative bg-white rounded-2xl overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,71,255,0.1)] border border-slate-100">
              <!-- Top bar / Browser-like UI -->
              <div class="bg-slate-50/80 backdrop-blur-md border-b border-slate-100 px-6 py-3 flex items-center justify-between">
                <div class="flex gap-1.5">
                  <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                  <span class="font-mono text-[9px] uppercase tracking-widest text-slate-400 font-bold">Live // Tarnów Hub</span>
                </div>
              </div>

              <div id="map" class="w-full aspect-square sm:aspect-video lg:h-[550px] z-0"></div>
              
              <!-- Floating UI elements -->
              <div class="absolute top-16 left-6 z-10 hidden sm:block">
                <div class="bg-white/90 backdrop-blur-md border border-slate-100 p-4 shadow-xl rounded-xl">
                  <p class="text-[9px] font-mono uppercase text-brand-primary font-bold tracking-[0.2em] mb-2">Lokalizacja serwisu</p>
                  <p class="text-brand-secondary font-display font-bold text-sm">ul. Tarnowska, 33-100 Tarnów</p>
                </div>
              </div>

              <div class="absolute bottom-0 left-0 right-0 z-10 p-6 bg-gradient-to-t from-white via-white/80 to-transparent">
                <div class="bg-brand-secondary text-white p-6 rounded-xl shadow-2xl flex flex-col sm:flex-row justify-between items-center gap-6">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-white/10 rounded-lg flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    </div>
                    <div>
                      <p class="text-xs text-white/60 font-medium">Jesteśmy tutaj</p>
                      <p class="font-display font-bold text-lg leading-tight">Centre Service IT</p>
                    </div>
                  </div>
                  <a href="https://www.google.com/maps/dir/?api=1&destination=50.0121,20.9858" target="_blank" class="w-full sm:w-auto bg-brand-primary text-white px-8 py-4 rounded-lg font-display font-bold text-sm hover:translate-y-[-2px] hover:shadow-xl hover:shadow-brand-primary/30 transition-all flex items-center justify-center gap-2">
                    Uruchom nawigację
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- EMERGENCY -->
    <section class="py-16 lg:py-32 bg-brand-primary text-white text-center">
      <div class="container-custom">
        <h2 class="text-3xl lg:text-7xl font-display font-black mb-6 tracking-tighter italic">Nagła awaria?</h2>
        <p class="text-xl lg:text-2xl mb-12 opacity-90 font-medium">Nie trać czasu. Zadzwoń do nas bezpośrednio — pomożemy natychmiast.</p>
        <a href="tel:504365205" class="bg-white text-brand-primary px-12 py-6 rounded-sm font-display font-bold text-2xl lg:text-4xl inline-flex items-center gap-4 hover:bg-brand-secondary hover:text-white transition-all shadow-2xl">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          504 365 205
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  function initMap() {
    const mapElement = document.getElementById('map');
    if (!mapElement || (mapElement as any)._leaflet_id) return;

    const tarnow = [50.0121, 20.9858];

    const map = L.map('map', {
      scrollWheelZoom: false,
      zoomControl: false,
      dragging: !L.Browser.mobile,
    }).setView(tarnow as L.LatLngExpression, 14);

    // Light/Voyager theme for a clean, architectural look
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 20
    }).addTo(map);

    // Modern "Live Signal" pulse marker
    const iconHtml = `
      <div class="relative flex items-center justify-center">
        <div class="absolute w-12 h-12 bg-brand-primary/20 rounded-full animate-[ping_2s_infinite]"></div>
        <div class="absolute w-8 h-8 bg-brand-primary/30 rounded-full animate-[pulse_2s_infinite]"></div>
        <div class="relative w-4 h-4 bg-brand-primary rounded-full border-2 border-white shadow-lg"></div>
      </div>
    `;

    const customIcon = L.divIcon({
      html: iconHtml,
      className: 'custom-div-icon',
      iconSize: [20, 20],
      iconAnchor: [10, 10]
    });

    L.marker(tarnow as L.LatLngExpression, { icon: customIcon }).addTo(map);
  }

  document.addEventListener('astro:page-load', initMap);
</script>

<style is:global>
  #map .leaflet-tile-pane {
    filter: grayscale(0.5) contrast(1.1) brightness(1.05);
  }

  .custom-div-icon {
    background: none !important;
    border: none !important;
  }
</style>
