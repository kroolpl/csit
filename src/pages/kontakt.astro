---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const services = [
  'Serwis elektroniki', 'Odzyskiwanie danych', 'Monitoring', 'Automatyka', 'Cyberbezpieczeństwo', 'Inne'
];
---

<Layout 
  title="Kontakt | Centre Service IT Tarnów" 
  description="Skontaktuj się z Centre Service IT w Tarnowie. Bezpłatna konsultacja i wycena usług. Zadzwoń: 504 365 205 lub odwiedź nas osobiście."
>
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO SECTION -->
    <header class="py-16 lg:py-32 bg-white border-b border-slate-100">
      <div class="container-custom">
        <span class="technical-label mb-6 block">Dane kontaktowe & Wsparcie</span>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-display font-black text-slate-900 leading-[0.95] mb-8 tracking-tighter">
          Twoja technologia, <br/> <span class="text-brand-primary">nasza odpowiedzialność.</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-500 max-w-3xl leading-relaxed">
          Skontaktuj się z nami, aby otrzymać bezpłatną diagnozę urządzenia lub wstępną wycenę systemu. Jesteśmy dostępni telefonicznie, mailowo oraz stacjonarnie w naszym punkcie w Tarnowie.
        </p>
      </div>
    </header>

    <!-- CONTACT CARDS GRID -->
    <section class="py-12 lg:py-20 bg-slate-50">
      <div class="container-custom">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {[
            { 
              label: 'Zadzwoń do nas', 
              val: '504 365 205', 
              sub: 'Pon – Pt: 09:00 – 18:00', 
              href: 'tel:504365205',
              icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z' 
            },
            { 
              label: 'Napisz e-mail', 
              val: 'biuro@csi.pl', 
              sub: 'biuro@centreserviceit.pl', 
              href: 'mailto:biuro@centreserviceit.pl',
              icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6' 
            },
            { 
              label: 'Odwiedź nas', 
              val: 'Tarnów, Małopolska', 
              sub: 'Ulica i numer serwisu', 
              href: '#map-section',
              icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 10a3 3 0 1 1 0-6 3 3 0 0 1 0 6z' 
            }
          ].map(card => (
            <a href={card.href} class="group bg-white p-8 border border-slate-200 shadow-sm hover:shadow-xl hover:border-brand-primary transition-all duration-300">
              <div class="w-12 h-12 bg-slate-50 flex items-center justify-center text-brand-primary mb-6 group-hover:bg-brand-primary group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={card.icon}></path>
                </svg>
              </div>
              <span class="font-mono text-[10px] uppercase tracking-widest text-slate-400 font-bold block mb-2">{card.label}</span>
              <div class="text-xl lg:text-2xl font-display font-black text-slate-900 group-hover:text-brand-primary transition-colors">{card.val}</div>
              <div class="text-xs text-slate-400 mt-2">{card.sub}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- INTERACTIVE MAP DASHBOARD -->
    <section id="map-section" class="py-12 lg:py-24 bg-white overflow-hidden">
      <div class="container-custom">
        <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
          <!-- Text -->
          <div class="lg:w-1/3">
            <span class="technical-label mb-4 block">Lokalizacja stacjonarna</span>
            <h2 class="text-3xl lg:text-5xl font-display font-black text-slate-900 mb-6 leading-tight">Znajdź nas <br/>w Tarnowie</h2>
            <p class="text-slate-500 mb-8 leading-relaxed">
              Nasz główny punkt serwisowy znajduje się w dogodnej lokalizacji w Tarnowie. Zapraszamy do osobistego dostarczenia sprzętu do diagnozy.
            </p>
            <div class="space-y-4">
              <a 
                href="https://www.google.com/maps/dir/?api=1&destination=50.0121,20.9858" 
                target="_blank"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-brand-primary text-white font-display font-bold text-base rounded-sm hover:bg-brand-secondary transition-all shadow-xl shadow-brand-primary/20"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
                Nawiguj do celu
              </a>
              <p class="text-[10px] font-mono uppercase tracking-widest text-slate-400 text-center sm:text-left">Kliknij, aby otworzyć w GPS</p>
            </div>
          </div>

          <!-- Map Dashboard -->
          <div class="lg:w-2/3 w-full relative">
            <div class="bg-slate-900 text-white px-6 py-3 flex justify-between items-center rounded-t-sm border-x border-t border-slate-900">
               <div class="flex items-center gap-3">
                  <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                  <span class="font-mono text-[10px] uppercase tracking-widest font-bold">Punkt serwisowy Tarnów</span>
               </div>
               <span class="font-mono text-[9px] text-white/40 uppercase tracking-widest">Status: Live</span>
            </div>
            <div class="aspect-square sm:aspect-video lg:h-[500px] border border-slate-900 shadow-2xl relative overflow-hidden group">
               <div id="map" class="w-full h-full z-10 cursor-crosshair"></div>
               <!-- Interactive Overlay for Mobile -->
               <a 
                 href="https://www.google.com/maps/dir/?api=1&destination=50.0121,20.9858" 
                 class="lg:hidden absolute inset-0 z-20 flex items-center justify-center bg-brand-primary/10 opacity-0 active:opacity-100 transition-opacity"
               >
                 <span class="bg-white text-brand-primary px-4 py-2 font-display font-bold shadow-2xl">Kliknij by nawigować</span>
               </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT FORM SECTION -->
    <section class="py-20 bg-slate-50 border-t border-slate-200">
      <div class="container-custom max-w-4xl">
        <div class="text-center mb-16">
          <span class="technical-label mb-4 block">Formularz zgłoszeniowy</span>
          <h2 class="text-3xl lg:text-6xl font-display font-black text-slate-900 mb-6 tracking-tighter">Wyślij szybkie zapytanie</h2>
          <p class="text-slate-500 max-w-xl mx-auto">Opisz swój problem lub zapytaj o wolny termin montażu. Odpowiadamy zazwyczaj w ciągu kilku godzin roboczych.</p>
        </div>

        <form class="bg-white p-8 lg:p-16 border border-slate-200 shadow-2xl space-y-8">
          <div class="grid sm:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="font-mono text-[10px] uppercase text-slate-400 font-bold tracking-widest">Imię i nazwisko</label>
              <input type="text" placeholder="Jan Kowalski" class="w-full border-b-2 border-slate-100 p-4 focus:outline-none focus:border-brand-primary transition-colors font-sans text-base" required />
            </div>
            <div class="space-y-2">
              <label class="font-mono text-[10px] uppercase text-slate-400 font-bold tracking-widest">Telefon / E-mail</label>
              <input type="text" placeholder="504 365 205" class="w-full border-b-2 border-slate-100 p-4 focus:outline-none focus:border-brand-primary transition-colors font-sans text-base" required />
            </div>
          </div>
          <div class="space-y-2">
            <label class="font-mono text-[10px] uppercase text-slate-400 font-bold tracking-widest">Opis Twojej sprawy</label>
            <textarea rows="5" placeholder="Np. Naprawa laptopa Dell, odzyskiwanie danych z karty SD..." class="w-full border-b-2 border-slate-100 p-4 focus:outline-none focus:border-brand-primary transition-colors font-sans text-base resize-none" required></textarea>
          </div>
          <div class="pt-4">
            <button type="submit" class="w-full bg-brand-primary text-white py-6 rounded-sm font-display font-bold text-lg hover:bg-brand-secondary transition-all shadow-xl shadow-brand-primary/30">
              Wyślij wiadomość do serwisu →
            </button>
            <p class="text-[10px] text-slate-400 text-center mt-6 font-mono uppercase tracking-widest">Państwa dane są przetwarzane wyłącznie w celu udzielenia odpowiedzi.</p>
          </div>
        </form>
      </div>
    </section>

    <!-- EMERGENCY SECTION -->
    <section class="py-16 lg:py-32 bg-brand-secondary text-white text-center">
      <div class="container-custom">
        <span class="technical-label text-brand-primary mb-6 block">Tryb awaryjny</span>
        <h2 class="text-3xl lg:text-7xl font-display font-bold mb-10 lg:mb-12 max-w-5xl mx-auto leading-tight">Pilna awaria? Nie czekaj. <br/>Zadzwoń od razu.</h2>
        <a href="tel:504365205" class="bg-brand-primary text-white px-8 lg:px-12 py-5 lg:py-8 rounded-sm font-display font-bold text-2xl lg:text-4xl inline-flex items-center gap-4 lg:gap-6 hover:bg-white hover:text-brand-primary transition-all shadow-2xl">
          📞 504 365 205
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  function initMap() {
    const mapElement = document.getElementById('map');
    if (!mapElement || (mapElement as any)._leaflet_id) return;

    const tarnow = [50.0121, 20.9858];

    const map = L.map('map', {
      scrollWheelZoom: false,
      zoomControl: false,
      dragging: !L.Browser.mobile,
    }).setView(tarnow as L.LatLngExpression, 14);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 20
    }).addTo(map);

    if (!L.Browser.mobile) {
      L.control.zoom({ position: 'bottomright' }).addTo(map);
    }

    const customIcon = L.icon({
      iconUrl: '/map-pin.svg',
      iconSize: [48, 48],
      iconAnchor: [24, 48]
    });

    L.marker(tarnow as L.LatLngExpression, { icon: customIcon }).addTo(map);

    // Map as a whole acts as a navigation trigger on mobile
    if (L.Browser.mobile) {
      mapElement.addEventListener('click', () => {
        window.open('https://www.google.com/maps/dir/?api=1&destination=50.0121,20.9858', '_blank');
      });
    }
  }

  document.addEventListener('astro:page-load', initMap);
</script>

<style is:global>
  /* Monochromatic Blue Map Filter */
  .leaflet-tile-pane {
    filter: hue-rotate(190deg) invert(8%) saturate(140%) brightness(102%) contrast(90%);
  }
  
  .leaflet-container {
    background: #0f172a !important; /* matches dark slate */
    font-family: inherit;
  }
</style>
