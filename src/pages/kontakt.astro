---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const contactMethods = [
  {
    title: 'Zadzwoń do nas',
    value: '504 365 205',
    sub: 'Pn – Pt: 9:00 – 18:00  ·  Sob: 9:00 – 14:00',
    href: 'tel:504365205',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
  },
  {
    title: 'Napisz e-mail',
    value: 'biuro@csi-tarnow.pl',
    sub: 'Odpowiadamy w ciągu kilku godzin',
    href: 'mailto:biuro@csi-tarnow.pl',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/><rect width="20" height="14" x="2" y="5" rx="2"/></svg>`
  },
  {
    title: 'Odwiedź nas',
    value: 'Tarnów, Małopolska',
    sub: 'Zapraszamy z urządzeniem do serwisu',
    href: '#mapa',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`
  }
];
---

<Layout 
  title="Kontakt | Centre Service IT Tarnów" 
  description="Skontaktuj się z profesjonalnym serwisem IT w Tarnowie. Bezpłatna wycena i doradztwo techniczne."
  breadcrumbs={[
    { name: "Kontakt", item: "/kontakt" }
  ]}
>
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO -->
    <section class="bg-white py-16 lg:py-32 border-b border-slate-100">
      <div class="container-custom">
        <span class="technical-label with-cursor mb-6 block">Kontakt i Wsparcie</span>
        <h1 class="text-4xl lg:text-7xl font-display font-black text-brand-secondary leading-tight mb-8">
          Twoja technologia, <br/> <span class="text-brand-primary">nasza odpowiedzialność.</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-600 max-w-3xl leading-relaxed">
          Masz pytanie dotyczące naprawy urządzenia lub montażu systemu bezpieczeństwa? Jesteśmy do Twojej dyspozycji — telefonicznie, mailowo lub osobiście w Tarnowie.
        </p>
      </div>
    </section>

    <!-- CONTACT CARDS -->
    <section class="py-12 bg-slate-50 border-b border-slate-200">
      <div class="container-custom">
        <div class="grid md:grid-cols-3 gap-6">
          {contactMethods.map(item => (
            <a href={item.href} class="bg-white p-8 border border-slate-200 shadow-sm hover:shadow-lg hover:border-brand-primary transition-all group flex gap-5 items-start">
              <div class="w-12 h-12 flex-shrink-0 bg-slate-50 flex items-center justify-center text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition-colors">
                <div set:html={item.icon} />
              </div>
              <div>
                <p class="font-mono text-[9px] uppercase tracking-widest text-slate-500 mb-1">{item.title}</p>
                <p class="font-display font-bold text-base text-brand-secondary group-hover:text-brand-primary transition-colors leading-tight mb-1">{item.value}</p>
                <p class="text-xs text-slate-500 leading-snug">{item.sub}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FORM + MAP SECTION -->
    <section id="mapa" class="py-16 lg:py-32 bg-white">
      <div class="container-custom">
        <!-- On mobile: map first (easier to find), form below. On desktop: side by side -->
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

          <!-- Map column — shown first on mobile via order -->
          <div class="order-1 lg:order-2">
            <div class="mb-5">
              <span class="technical-label with-cursor mb-2 block">Lokalizacja</span>
              <h2 class="text-2xl lg:text-3xl font-display font-bold text-brand-secondary">Gdzie nas znaleźć?</h2>
            </div>

            <!-- Map container -->
            <div class="border border-slate-200 overflow-hidden shadow-lg">
              <!-- Status bar -->
              <div class="bg-slate-50 border-b border-slate-200 px-4 py-2.5 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                  <span class="font-mono text-[9px] uppercase tracking-widest text-slate-500 font-bold">Tarnów, Małopolska</span>
                </div>
                <a
                  href="https://www.google.com/maps/dir/?api=1&destination=50.0121,20.9858"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-[9px] uppercase tracking-widest text-brand-primary font-bold hover:text-brand-secondary transition-colors flex items-center gap-1"
                >
                  Nawiguj
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              </div>

              <!-- Map itself — fixed height, no aspect ratio tricks -->
              <div id="map" class="w-full h-[280px] sm:h-[360px] lg:h-[420px] z-0 bg-slate-100"></div>

              <!-- Info strip below map — not overlaid -->
              <div class="bg-white border-t border-slate-200 p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 bg-brand-primary/10 flex items-center justify-center text-brand-primary flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p class="font-display font-bold text-sm text-brand-secondary leading-tight">Centre Service IT</p>
                    <p class="text-xs text-slate-500">Tarnów, Małopolska</p>
                  </div>
                </div>
                <a
                  href="https://www.google.com/maps/dir/?api=1&destination=50.0121,20.9858"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full sm:w-auto flex items-center justify-center gap-2 bg-brand-primary text-white px-6 py-3 font-display font-bold text-sm hover:bg-brand-secondary active:scale-[0.98] transition-all shadow-md shadow-brand-primary/20"
                >
                  Uruchom nawigację
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              </div>
            </div>

            <!-- Tap to interact hint (mobile) -->
            <p id="map-tap-hint" class="mt-3 text-center text-xs text-slate-400 font-mono uppercase tracking-widest sm:hidden">
              Dotknij mapę, aby ją aktywować
            </p>
          </div>

          <!-- Contact Form — second on mobile, first on desktop -->
          <div class="order-2 lg:order-1">
            <div class="mb-8">
              <span class="technical-label with-cursor mb-2 block">Napisz do nas</span>
              <h2 class="text-2xl lg:text-3xl font-display font-bold text-brand-secondary">Wyślij wiadomość</h2>
              <p class="text-slate-600 mt-3 text-sm leading-relaxed">Opisz swój problem techniczny, a my wrócimy z propozycją i wyceną.</p>
            </div>
            
            <form class="space-y-5" novalidate>
              <div class="grid sm:grid-cols-2 gap-5">
                <div class="space-y-1.5">
                  <label class="font-mono text-[9px] uppercase text-slate-500 font-bold tracking-widest block">Imię i nazwisko</label>
                  <input
                    type="text"
                    placeholder="Jan Kowalski"
                    class="w-full bg-white border border-slate-200 px-4 py-3.5 focus:outline-none focus:border-brand-primary transition-colors text-sm"
                    required
                  />
                </div>
                <div class="space-y-1.5">
                  <label class="font-mono text-[9px] uppercase text-slate-500 font-bold tracking-widest block">Telefon lub e-mail</label>
                  <input
                    type="text"
                    placeholder="504 365 205"
                    class="w-full bg-white border border-slate-200 px-4 py-3.5 focus:outline-none focus:border-brand-primary transition-colors text-sm"
                    required
                  />
                </div>
              </div>
              <div class="space-y-1.5">
                <label class="font-mono text-[9px] uppercase text-slate-500 font-bold tracking-widest block">W czym możemy pomóc?</label>
                <textarea
                  rows="5"
                  placeholder="Opisz usterkę lub zapytaj o usługę..."
                  class="w-full bg-white border border-slate-200 px-4 py-3.5 focus:outline-none focus:border-brand-primary transition-colors text-sm resize-none"
                  required
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full bg-brand-primary text-white py-4 font-display font-bold text-base hover:bg-brand-secondary active:scale-[0.98] transition-all shadow-lg shadow-brand-primary/20"
              >
                Wyślij zapytanie →
              </button>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- EMERGENCY CTA -->
    <section class="py-16 lg:py-32 bg-brand-primary text-white text-center">
      <div class="container-custom">
        <h2 class="text-3xl lg:text-7xl font-display font-black mb-6 tracking-tighter italic">Nagła awaria?</h2>
        <p class="text-xl lg:text-2xl mb-12 opacity-90 font-medium">Nie trać czasu. Zadzwoń bezpośrednio — pomożemy natychmiast.</p>
        <a href="tel:504365205" class="bg-white text-brand-primary px-10 lg:px-16 py-5 lg:py-7 font-display font-bold text-2xl lg:text-4xl inline-flex items-center gap-4 hover:bg-brand-secondary hover:text-white transition-all shadow-2xl active:scale-[0.98]">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          504 365 205
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  function initMap() {
    const mapElement = document.getElementById('map');
    if (!mapElement || (mapElement as any)._leaflet_id) return;

    const tarnow: L.LatLngExpression = [50.0121, 20.9858];

    // On mobile: disable dragging until user taps (prevents scroll hijack)
    const isMobile = window.matchMedia('(max-width: 640px)').matches;

    const map = L.map('map', {
      scrollWheelZoom: false,
      zoomControl: false,
      dragging: !isMobile,
      tap: false, // prevents ghost clicks on iOS
    }).setView(tarnow, 15);

    // Add zoom control in a thumb-friendly bottom-right position
    L.control.zoom({ position: 'bottomright' }).addTo(map);

    // Voyager tile layer — clean, architectural
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 20
    }).addTo(map);

    // Pulsing marker
    const iconHtml = `
      <div style="position:relative;display:flex;align-items:center;justify-content:center;width:40px;height:40px;">
        <div style="position:absolute;width:36px;height:36px;background:rgba(0,71,255,0.15);border-radius:50%;animation:mapPing 2s ease-in-out infinite;"></div>
        <div style="position:absolute;width:20px;height:20px;background:rgba(0,71,255,0.25);border-radius:50%;animation:mapPulse 2s ease-in-out infinite;"></div>
        <div style="position:relative;width:12px;height:12px;background:#0047ff;border-radius:50%;border:2.5px solid white;box-shadow:0 2px 8px rgba(0,71,255,0.5);"></div>
      </div>
    `;

    const customIcon = L.divIcon({
      html: iconHtml,
      className: '',
      iconSize: [40, 40],
      iconAnchor: [20, 20],
    });

    L.marker(tarnow, { icon: customIcon }).addTo(map);

    // Mobile: enable drag on first tap, hide hint
    if (isMobile) {
      const hint = document.getElementById('map-tap-hint');
      mapElement.addEventListener('click', () => {
        map.dragging.enable();
        if (hint) hint.style.display = 'none';
      }, { once: true });
    }
  }

  document.addEventListener('astro:page-load', initMap);
</script>

<style is:global>
  #map .leaflet-tile-pane {
    filter: grayscale(0.35) contrast(1.05) brightness(1.05);
  }

  /* Zoom control styling */
  #map .leaflet-control-zoom {
    border: none !important;
    box-shadow: 0 2px 12px rgba(0,26,77,0.12) !important;
    margin: 0 12px 12px 0 !important;
  }
  #map .leaflet-control-zoom a {
    width: 36px !important;
    height: 36px !important;
    line-height: 36px !important;
    font-size: 18px !important;
    color: #001a4d !important;
    background: white !important;
    border-color: #e2e8f0 !important;
  }
  #map .leaflet-control-zoom a:hover {
    background: #f8fafc !important;
    color: #0047ff !important;
  }

  @keyframes mapPing {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.5); opacity: 0; }
  }
  @keyframes mapPulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.2); opacity: 0.4; }
  }
</style>
