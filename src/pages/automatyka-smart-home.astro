---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import smarthomeImg from '../assets/images/smarthome.webp';

const gateAutomation = [
  { title: 'Bramy wjazdowe', features: ['Montaż napędów skrzydłowych i przesuwnych', 'Konfiguracja pilotów i domofonów', 'Integracja z alarmem i monitoringiem', 'Naprawy mechaniczne i elektryczne'] },
  { title: 'Bramy segmentowe', features: ['Montaż bram garażowych i przemysłowych', 'Dobór napędów do wagi i wielkości', 'Regulacja siły i prędkości otwierania', 'Serwis pogwarancyjny i wymiana części'] }
];

const smartHomeFeatures = [
  { title: 'Oświetlenie', desc: 'Sterowanie głosem i aplikacją, harmonogramy.' },
  { title: 'Ogrzewanie', desc: 'Inteligentne zarządzanie temperaturą w każdym pokoju.' },
  { title: 'Rolety', desc: 'Automatyczne sterowanie zależne od pory dnia.' },
  { title: 'Bezpieczeństwo', desc: 'Integracja z alarmem i powiadomienia na telefon.' }
];
---

<Layout 
  title="Automatyka Bram i Smart Home | Tarnów" 
  description="Profesjonalny montaż automatyki do bram wjazdowych i segmentowych oraz systemów smart home (FIBARO) w Tarnowie. Tel: 504 365 205."
>
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO -->
    <header class="py-16 lg:py-40 bg-white border-b border-slate-100">
      <div class="container-custom">
        <span class="technical-label with-cursor mb-6 block">Bramy wjazdowe · Bramy segmentowe · Inteligentny dom</span>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-display font-black text-slate-900 leading-[0.95] tracking-tighter mb-8 max-w-5xl">
          Wygoda i bezpieczeństwo zaczynają się <span class="text-brand-primary">przy wjeździe.</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-500 max-w-2xl mb-12 leading-relaxed">
          Montujemy i serwisujemy automatykę do bram oraz budujemy inteligentne systemy zarządzania domem. Szybko, solidnie i z pełną gwarancją.
        </p>
        <a href="tel:504365205" class="bg-brand-primary text-white px-8 lg:px-10 py-4 lg:py-5 rounded-sm font-display font-bold text-base lg:text-lg inline-flex items-center gap-4 hover:bg-brand-secondary transition-all shadow-xl">
          → Umów bezpłatną wycenę
        </a>
      </div>
    </header>

    <!-- GATE AUTOMATION -->
    <section class="section-padding bg-slate-50">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-24 items-start">
          <div>
            <span class="technical-label with-cursor mb-4 block">Automatyka bramowa</span>
            <h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary mb-6 lg:mb-8 leading-tight">Bramy, które działają — bez zawodzeń</h2>
            <p class="text-xl text-slate-600 mb-12 leading-relaxed">
              Zapewniamy kompleksowy montaż i serwis napędów do bram wjazdowych oraz garażowych. Wykorzystujemy sprawdzone rozwiązania, które gwarantują niezawodność przez lata.
            </p>
            <div class="bg-white p-8 border border-slate-200 shadow-sm">
              <h4 class="font-display font-bold text-brand-primary uppercase tracking-wider text-sm mb-4">Serwis i awaryjne naprawy</h4>
              <p class="text-slate-700 text-sm leading-relaxed mb-6">Szybkie interwencje serwisowe, wymiana siłowników, sprężyn i sterowników. Przeglądy konserwacyjne zapobiegające awariom.</p>
              <a href="tel:504365205" class="text-brand-secondary font-bold hover:underline">Zadzwoń w sprawie serwisu →</a>
            </div>
          </div>
          <div class="space-y-8">
            {gateAutomation.map(item => (
              <div class="bg-white p-8 lg:p-12 border border-slate-200 shadow-xl">
                <h3 class="text-xl lg:text-2xl font-display font-bold text-brand-secondary mb-6 lg:mb-8">{item.title}</h3>
                <ul class="space-y-4">
                  {item.features.map(f => (
                    <li class="flex items-start gap-4 text-slate-600 text-sm">
                      <svg class="text-brand-primary mt-1 flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- SMART HOME -->
    <section class="section-padding bg-white overflow-hidden">
      <div class="container-custom">
        <div class="flex flex-col lg:flex-row gap-20 items-center">
          <div class="lg:w-1/2 relative group">
             <div class="aspect-square bg-slate-100 border border-slate-200 rounded-sm overflow-hidden relative shadow-2xl">
                <Image 
                  src={smarthomeImg} 
                  alt="Nowoczesny inteligentny dom sterowany systemem FIBARO" 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-brand-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="technical-label text-white text-[60px] lg:text-[80px] font-black leading-none opacity-20 absolute inset-0 flex items-center justify-center pointer-events-none mix-blend-overlay">SMART HOME</div>
             </div>
             <div class="absolute -top-6 -right-6 lg:-top-10 lg:-right-10 bg-brand-primary text-white p-6 lg:p-8 shadow-2xl max-w-[200px] lg:max-w-none z-20">
                <p class="font-display font-bold text-xs lg:text-base leading-tight">Autoryzowany partner systemów FIBARO</p>
             </div>
          </div>
          <div class="lg:w-1/2">
            <span class="technical-label with-cursor mb-4 block">Inteligentny dom</span>
            <h2 class="text-4xl lg:text-6xl font-display font-bold text-brand-secondary mb-8">Twój dom, który słucha</h2>
            <p class="text-xl text-slate-600 mb-12 leading-relaxed">
              Systemy inteligentnego domu pozwalają zarządzać oświetleniem, ogrzewaniem, roletami i alarmem — z jednej aplikacji, z dowolnego miejsca na świecie.
            </p>
            <div class="grid sm:grid-cols-2 gap-8">
              {smartHomeFeatures.map(f => (
                <div>
                  <h4 class="font-display font-bold text-brand-secondary mb-2">{f.title}</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">{f.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-padding bg-brand-secondary text-white text-center">
      <div class="container-custom">
        <h2 class="text-3xl lg:text-6xl font-display font-bold mb-8 max-w-4xl mx-auto">Zaplanujmy razem Twój inteligentny dom lub automatykę bramy.</h2>
        <a href="tel:504365205" class="bg-brand-primary text-white px-8 lg:px-12 py-5 lg:py-6 rounded-sm font-display font-bold text-xl lg:text-2xl inline-flex items-center gap-4 hover:bg-white hover:text-brand-primary transition-all shadow-2xl">
          → 504 365 205
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
