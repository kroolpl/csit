---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import print3dImg from '../assets/images/rob-wingate-nHRfTeqAxjs-unsplash.jpg';

const services = [
  {
    title: 'Strony internetowe i marketing',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    desc: 'Strony i sklepy e-commerce, SEO, kampanie Google/Meta Ads oraz identyfikacja wizualna.',
    points: ['Modern Design & UX', 'Search Engine Optimization', 'Social Media Management']
  },
  {
    title: 'Druk 3D i Prototypowanie',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 9V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v5"/><rect x="6" y="14" width="12" height="8" rx="1"/></svg>`,
    desc: 'Profesjonalne usługi druku 3D dla firm i hobbystów — od projektu po gotowy model.',
    points: ['Prototypy techniczne', 'Części zamienne', 'Modele architektoniczne']
  },
  {
    title: 'Chmura i serwery NAS',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19a5.5 5.5 0 0 0 2.5-10.5 8.5 8.5 0 1 0-16.5 4.5 5 5 0 1 0 1.5 9.5h12.5z"/></svg>`,
    desc: 'Konfiguracja bezpiecznych rozwiązań do przechowywania i synchronizacji danych.',
    points: ['Synology Specialists', 'Data Migration', 'Cloud Backup Integration']
  },
  {
    title: 'Analizy statystyczne',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    desc: 'Profesjonalne analizy danych dla studentów i badaczy (SPSS, R, Excel).',
    points: ['Prace magisterskie', 'Badania rynkowe', 'Wizualizacja danych']
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Usługi IT & Technologia",
  "description": "Strony internetowe, marketing online, druk 3D i analizy statystyczne w Centre Service IT Tarnów. Twój partner w technologii.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Centre Service IT",
    "url": "https://csi-tarnow.pl"
  },
  "areaServed": {
    "@type": "State",
    "name": "Małopolska"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Usługi IT i Technologiczne",
    "itemListElement": services.map(s => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": s.title
      }
    }))
  }
};
---

<Layout 
  title="Usługi IT, Strony WWW i Druk 3D Tarnów" 
  description="Strony internetowe, marketing online, druk 3D i analizy statystyczne w Centre Service IT Tarnów. Twój partner w technologii. Tel: 504 365 205."
  breadcrumbs={[
    { name: "Usługi", item: "/#uslugi" },
    { name: "Usługi IT", item: "/uslugi-it-technologia" }
  ]}
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(serviceSchema)} />
  <Navbar />
  
  <main class="pt-20">
    <!-- HERO -->
    <header class="py-16 lg:py-40 bg-white border-b border-slate-100">
      <div class="container-custom">
        <span class="technical-label with-cursor mb-6 block">Strony internetowe · Druk 3D · Chmura · Marketing</span>
        <h1 class="text-4xl sm:text-6xl lg:text-8xl font-display font-black text-slate-900 leading-[0.95] tracking-tighter mb-8 max-w-5xl">
          Kompleksowe wsparcie <span class="text-brand-primary">technologiczne.</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-600 max-w-2xl mb-12 leading-relaxed">
          Od nowoczesnej strony internetowej po druk 3D i analizę danych — Centre Service IT to Twój partner technologiczny w jednym miejscu.
        </p>
        <a href="tel:504365205" class="bg-brand-primary text-white px-8 lg:px-10 py-4 lg:py-5 rounded-sm font-display font-bold text-base lg:text-lg inline-flex items-center gap-4 hover:bg-brand-secondary transition-all shadow-xl shadow-brand-primary/20">
          → Zadzwoń: 504 365 205
        </a>
      </div>
    </header>

    <!-- SERVICES GRID -->
    <section class="section-padding bg-slate-50">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-px bg-slate-200 border border-slate-200 shadow-2xl">
          {services.map(s => (
            <div class="bg-white p-8 lg:p-16 hover:bg-slate-50 transition-colors flex flex-col justify-between">
              <div>
                <div class="text-brand-primary mb-6 lg:mb-8" set:html={s.icon} />
                <h3 class="text-2xl lg:text-3xl font-display font-bold text-brand-secondary mb-4 lg:mb-6">{s.title}</h3>
                <p class="text-slate-600 mb-8 lg:mb-10 leading-relaxed text-base lg:text-lg">{s.desc}</p>
              </div>
              <ul class="space-y-3">
                {s.points.map(p => (
                  <li class="flex items-center gap-3 text-xs font-mono uppercase tracking-widest text-brand-primary font-bold">
                    <span class="w-2 h-[1px] bg-brand-primary"></span>
                    {p}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3D PRINT DETAIL -->
    <section class="section-padding bg-white overflow-hidden">
      <div class="container-custom">
        <div class="flex flex-col lg:flex-row gap-24 items-center">
           <div class="lg:w-1/2">
             <span class="technical-label with-cursor mb-4 block">Druk 3D</span>
             <h2 class="text-3xl lg:text-6xl font-display font-bold text-brand-secondary mb-6 lg:mb-8 leading-tight">Twoje pomysły w trójwymiarze</h2>
             <p class="text-xl text-slate-600 mb-8 leading-relaxed">
               Oferujemy profesjonalne usługi projektowania i druku 3D dla firm, konstruktorów i twórców. Od prototypu po gotowy produkt.
             </p>
             <div class="bg-slate-50 p-8 border-l-4 border-brand-primary">
                <p class="text-brand-secondary font-display font-bold italic">
                  "Przynosisz pomysł lub plik — my drukujemy gotowy element. Możemy też zaprojektować model od podstaw."
                </p>
             </div>
           </div>
           <div class="lg:w-1/2 relative group">
              <div class="aspect-video bg-slate-100 border border-slate-200 rounded-sm overflow-hidden relative shadow-2xl">
                 <Image 
                   src={print3dImg} 
                   alt="Profesjonalny druk 3D w akcji - Centre Service IT" 
                   class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                 />
                 <div class="absolute inset-0 bg-brand-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                 <div class="technical-label text-white text-[60px] lg:text-[80px] font-black leading-none opacity-10 absolute inset-0 flex items-center justify-center pointer-events-none mix-blend-overlay">PRECISION</div>
              </div>
              <div class="absolute -bottom-4 -right-4 lg:-bottom-6 lg:-right-6 bg-brand-secondary text-white p-5 lg:p-6 shadow-xl max-w-[180px] lg:max-w-none z-20">
                 <span class="font-mono text-[9px] lg:text-[10px] uppercase tracking-[0.2em] block mb-2">Technologia</span>
                 <p class="font-display font-bold text-sm lg:text-base">FDM & SLA Printing</p>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- WEB CTA -->
    <section class="section-padding bg-brand-secondary text-white">
      <div class="container-custom">
        <div class="flex flex-col lg:flex-row gap-20 items-center">
          <div class="flex-1">
             <h2 class="text-3xl lg:text-6xl font-display font-bold mb-6">Twoja firma w internecie — widoczna i skuteczna</h2>
             <p class="text-lg lg:text-xl text-white/70 mb-0">Dobra strona internetowa to nie koszt — to inwestycja, która pracuje dla Ciebie 24 godziny na dobę.</p>
          </div>
          <a href="tel:504365205" class="bg-brand-primary text-white px-8 lg:px-12 py-4 lg:py-6 rounded-sm font-display font-bold text-xl lg:text-2xl hover:bg-white hover:text-brand-primary transition-all flex-shrink-0">
             Start Your Project →
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
