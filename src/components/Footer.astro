---
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-slate-50 overflow-hidden">
  <!-- Technical Texture Layer -->
  <div class="absolute inset-0 opacity-[0.4] pointer-events-none" 
    style="background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 24px 24px;">
  </div>
  
  <!-- Circuit Line Top Border -->
  <div class="relative w-full h-1 bg-slate-200">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-full bg-brand-primary"></div>
    <div class="absolute top-0 left-[10%] w-2 h-3 bg-slate-300"></div>
    <div class="absolute top-0 right-[10%] w-2 h-3 bg-slate-300"></div>
  </div>

  <div class="container-custom relative pt-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      <div class="lg:col-span-2">
        <a href="/" class="group flex items-center gap-3 mb-8">
          <div class="flex items-center font-mono font-bold text-xl tracking-tighter">
            <span class="text-brand-secondary group-hover:text-brand-primary transition-colors">[CSIT]</span>
            <span class="w-[0.6em] h-[1.2em] bg-brand-primary ml-1 animate-pulse"></span>
          </div>
          <div class="flex flex-col leading-tight border-l border-slate-200 pl-3">
            <span class="technical-label">Technologia & Bezpieczeństwo</span>
            <span class="text-[8px] font-mono text-slate-400 uppercase tracking-widest">Tarnów, PL</span>
          </div>
        </a>
        <p class="text-slate-600 max-w-sm mb-10 leading-relaxed text-sm lg:text-base">
          Profesjonalny serwis elektroniki, odzyskiwanie danych i zaawansowane systemy zabezpieczeń. Budujemy fundamenty Twojego cyfrowego spokoju.
        </p>
        <div class="flex flex-col gap-5">
          <a href="tel:504365205" class="flex items-center gap-4 text-brand-secondary font-bold text-lg group w-fit">
            <div class="w-10 h-10 bg-white border border-slate-200 flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-all shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <span class="group-hover:text-brand-primary transition-colors">504 365 205</span>
          </a>
          <div class="flex items-center gap-4 text-slate-600 font-medium group">
            <div class="w-10 h-10 bg-white border border-slate-200 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <span>Tarnów, Małopolska</span>
          </div>
        </div>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-8">
          <div class="w-1.5 h-1.5 bg-brand-primary"></div>
          <h4 class="font-mono font-bold text-brand-secondary uppercase tracking-widest text-xs">Usługi</h4>
        </div>
        <ul class="space-y-4">
          <li><a href="/serwis-elektroniki" class="text-slate-500 hover:text-brand-primary transition-colors text-sm font-medium flex items-center gap-2 group">
            <span class="w-0 group-hover:w-2 h-[1px] bg-brand-primary transition-all"></span>
            Serwis Elektroniki
          </a></li>
          <li><a href="/odzyskiwanie-danych" class="text-slate-500 hover:text-brand-primary transition-colors text-sm font-medium flex items-center gap-2 group">
            <span class="w-0 group-hover:w-2 h-[1px] bg-brand-primary transition-all"></span>
            Odzyskiwanie Danych
          </a></li>
          <li><a href="/monitoring-alarmy" class="text-slate-500 hover:text-brand-primary transition-colors text-sm font-medium flex items-center gap-2 group">
            <span class="w-0 group-hover:w-2 h-[1px] bg-brand-primary transition-all"></span>
            Monitoring & Alarmy
          </a></li>
          <li><a href="/automatyka-smart-home" class="text-slate-500 hover:text-brand-primary transition-colors text-sm font-medium flex items-center gap-2 group">
            <span class="w-0 group-hover:w-2 h-[1px] bg-brand-primary transition-all"></span>
            Automatyka Bram
          </a></li>
          <li><a href="/cyberbezpieczenstwo" class="text-slate-500 hover:text-brand-primary transition-colors text-sm font-medium flex items-center gap-2 group">
            <span class="w-0 group-hover:w-2 h-[1px] bg-brand-primary transition-all"></span>
            Cyberbezpieczeństwo
          </a></li>
          <li><a href="/uslugi-it-technologia" class="text-slate-500 hover:text-brand-primary transition-colors text-sm font-medium flex items-center gap-2 group">
            <span class="w-0 group-hover:w-2 h-[1px] bg-brand-primary transition-all"></span>
            Usługi IT
          </a></li>
        </ul>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-8">
          <div class="w-1.5 h-1.5 bg-brand-primary"></div>
          <h4 class="font-mono font-bold text-brand-secondary uppercase tracking-widest text-xs">Obszar</h4>
        </div>
        <ul class="space-y-4 text-sm text-slate-500 font-medium">
          <li class="flex items-center gap-2 italic">Tarnów (Hub)</li>
          <li>Kraków</li>
          <li>Bochnia</li>
          <li>Brzesko</li>
          <li>Dębica</li>
          <li>Wojnicz</li>
        </ul>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-8">
          <div class="w-1.5 h-1.5 bg-brand-primary"></div>
          <h4 class="font-mono font-bold text-brand-secondary uppercase tracking-widest text-xs">Terminy</h4>
        </div>
        <ul class="space-y-4 text-sm text-slate-500 font-medium">
          <li class="flex justify-between border-b border-slate-200/60 pb-2"><span>Pn – Pt</span> <span>9:00 – 18:00</span></li>
          <li class="flex justify-between border-b border-slate-200/60 pb-2"><span>Sobota</span> <span>9:00 – 14:00</span></li>
          <li class="flex justify-between text-brand-primary/60"><span>Niedziela</span> <span>Standby</span></li>
        </ul>
      </div>
    </div>

    <!-- Technical Status Bar -->
    <div class="pt-8 border-t border-slate-200 flex flex-col lg:flex-row justify-between items-center gap-6">
      <div class="flex flex-col md:flex-row items-center gap-4 lg:gap-8">
        <p class="text-[10px] text-slate-400 font-mono tracking-widest uppercase">
          © {currentYear} CENTRE SERVICE IT
        </p>
        <div class="flex items-center gap-4 text-[9px] font-mono uppercase tracking-[0.2em] text-slate-300">
          <span class="flex items-center gap-1.5"><span class="w-1 h-1 bg-emerald-500 rounded-full"></span> Secure Connection</span>
          <span class="hidden md:inline">Node: TRN_MASTER_01</span>
          <span class="hidden md:inline">v6.1.8_STABLE</span>
        </div>
      </div>
      <div class="flex gap-8">
        <a href="#" class="text-[9px] text-slate-400 hover:text-brand-primary transition-colors font-mono uppercase tracking-[0.2em]">Prywatność</a>
        <a href="#" class="text-[9px] text-slate-400 hover:text-brand-primary transition-colors font-mono uppercase tracking-[0.2em]">Regulamin</a>
      </div>
    </div>
  </div>
</footer>
