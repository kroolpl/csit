---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-50 border-t border-slate-200 pt-20 pb-10">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      <div class="lg:col-span-2">
        <a href="/" class="group flex items-center gap-3 mb-6">
          <div class="flex items-center font-mono font-bold text-xl tracking-tighter">
            <span class="text-brand-secondary group-hover:text-brand-primary transition-colors">[CSIT]</span>
            <span class="w-[0.6em] h-[1.2em] bg-brand-primary ml-1 animate-pulse"></span>
          </div>
          <div class="flex flex-col leading-tight border-l border-slate-200 pl-3">
            <span class="technical-label">Technologia & Bezpieczeństwo</span>
            <span class="text-[8px] font-mono text-slate-400 uppercase tracking-widest">Tarnów, PL</span>
          </div>
        </a>
        <p class="text-slate-600 max-w-sm mb-8">
          Kompleksowy serwis elektroniki, odzyskiwanie danych i profesjonalne systemy bezpieczeństwa w Tarnowie i całej Małopolsce.
        </p>
        <div class="space-y-4">
          <a href="tel:504365205" class="flex items-center gap-3 text-brand-primary font-bold text-lg hover:underline decoration-2 underline-offset-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            504 365 205
          </a>
          <p class="flex items-center gap-3 text-slate-600 font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            Tarnów, Małopolska
          </p>
        </div>
      </div>

      <div>
        <h4 class="font-display font-bold text-brand-secondary mb-6 uppercase tracking-wider text-sm">Usługi</h4>
        <ul class="space-y-3">
          <li><a href="/serwis-elektroniki" class="text-slate-600 hover:text-brand-primary transition-colors text-sm">Serwis Elektroniki</a></li>
          <li><a href="/odzyskiwanie-danych" class="text-slate-600 hover:text-brand-primary transition-colors text-sm">Odzyskiwanie Danych</a></li>
          <li><a href="/monitoring-alarmy" class="text-slate-600 hover:text-brand-primary transition-colors text-sm">Monitoring & Alarmy</a></li>
          <li><a href="/automatyka-smart-home" class="text-slate-600 hover:text-brand-primary transition-colors text-sm">Automatyka Bram</a></li>
          <li><a href="/cyberbezpieczenstwo" class="text-slate-600 hover:text-brand-primary transition-colors text-sm">Cyberbezpieczeństwo</a></li>
          <li><a href="/uslugi-it-technologia" class="text-slate-600 hover:text-brand-primary transition-colors text-sm">Usługi IT</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold text-brand-secondary mb-6 uppercase tracking-wider text-sm">Obszar działania</h4>
        <ul class="space-y-3 text-sm text-slate-600">
          <li>Tarnów</li>
          <li>Kraków</li>
          <li>Bochnia</li>
          <li>Brzesko</li>
          <li>Dębica</li>
          <li>Wojnicz</li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold text-brand-secondary mb-6 uppercase tracking-wider text-sm">Godziny otwarcia</h4>
        <ul class="space-y-3 text-sm text-slate-600">
          <li class="flex justify-between"><span>Pn – Pt:</span> <span class="font-medium">9:00 – 18:00</span></li>
          <li class="flex justify-between"><span>Sobota:</span> <span class="font-medium">9:00 – 14:00</span></li>
          <li class="flex justify-between"><span>Niedziela:</span> <span class="font-medium">Zamknięte</span></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-slate-500 font-mono">
        © {currentYear} CENTRE SERVICE IT. WSZELKIE PRAWA ZASTRZEŻONE.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-slate-500 hover:text-brand-primary transition-colors font-mono uppercase tracking-widest">Polityka Prywatności</a>
        <a href="#" class="text-xs text-slate-500 hover:text-brand-primary transition-colors font-mono uppercase tracking-widest">Regulamin Serwisu</a>
      </div>
    </div>
  </div>
</footer>
