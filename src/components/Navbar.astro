---
import MobileMenu from './MobileMenu.tsx';

const currentPath = Astro.url.pathname;

const serviceItems = [
  { label: 'Serwis Elektroniki', href: '/serwis-elektroniki', desc: 'Naprawa laptopów, smartfonów, sprzętu AGD' },
  { label: 'Odzyskiwanie Danych', href: '/odzyskiwanie-danych', desc: 'HDD, SSD, pendrive, karty pamięci' },
  { label: 'Monitoring & Alarmy', href: '/monitoring-alarmy', desc: 'CCTV, systemy alarmowe, kontrola dostępu' },
  { label: 'Automatyka & Smart Home', href: '/automatyka-smart-home', desc: 'Bramy wjazdowe, systemy FIBARO' },
  { label: 'Cyberbezpieczeństwo', href: '/cyberbezpieczenstwo', desc: 'Ochrona firm, firewall, backup, NAS' },
  { label: 'Usługi IT & Technologia', href: '/uslugi-it-technologia', desc: 'Strony WWW, druk 3D, chmura' },
];

const isServicePage = serviceItems.some(item => currentPath.startsWith(item.href));
---

<nav class="fixed top-0 left-0 w-full z-[100] bg-white/80 backdrop-blur-md border-b border-slate-200">
  <div class="container-custom h-20 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-3">
      <div class="flex items-center font-mono font-bold text-xl tracking-tighter">
        <span class="text-brand-secondary group-hover:text-brand-primary transition-colors">[CSIT]</span>
        <span class="w-[0.6em] h-[1.2em] bg-brand-primary ml-1 animate-pulse"></span>
      </div>
      <div class="hidden sm:flex flex-col leading-tight border-l border-slate-200 pl-3">
        <span class="technical-label">Technologia & Bezpieczeństwo</span>
        <span class="text-[8px] font-mono text-slate-400 uppercase tracking-widest">Tarnów, PL</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center gap-6 xl:gap-8">
      <!-- Home -->
      <a
        href="/"
        class={`text-sm font-medium transition-colors ${currentPath === '/' ? 'text-brand-primary' : 'text-slate-600 hover:text-brand-primary'}`}
      >
        Strona Główna
      </a>

      <!-- Services Dropdown -->
      <div class="relative group/services">
        <button
          class={`flex items-center gap-1.5 text-sm font-medium transition-colors py-1 ${isServicePage ? 'text-brand-primary' : 'text-slate-600 hover:text-brand-primary'}`}
          aria-haspopup="true"
        >
          Usługi
          <svg
            class="w-3.5 h-3.5 transition-transform duration-200 group-hover/services:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown Panel -->
        <div class="absolute top-full -left-4 pt-3 opacity-0 invisible pointer-events-none group-hover/services:opacity-100 group-hover/services:visible group-hover/services:pointer-events-auto transition-all duration-200 ease-out">
          <div class="bg-white border border-slate-200 shadow-2xl shadow-slate-900/10 w-72 py-2">
            {serviceItems.map(item => (
              <a
                href={item.href}
                class={`flex flex-col gap-0.5 px-5 py-3 mx-1 transition-all border-l-2 hover:bg-slate-50 group/item ${
                  currentPath.startsWith(item.href)
                    ? 'border-brand-primary bg-brand-primary/5'
                    : 'border-transparent hover:border-brand-primary'
                }`}
              >
                <span class={`text-sm font-semibold transition-colors ${
                  currentPath.startsWith(item.href)
                    ? 'text-brand-primary'
                    : 'text-brand-secondary group-hover/item:text-brand-primary'
                }`}>
                  {item.label}
                </span>
                <span class="text-[10px] text-slate-400 leading-snug">{item.desc}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- O nas -->
      <a
        href="/o-nas"
        class={`text-sm font-medium transition-colors ${currentPath === '/o-nas' ? 'text-brand-primary' : 'text-slate-600 hover:text-brand-primary'}`}
      >
        O nas
      </a>

      <!-- Kontakt -->
      <a
        href="/kontakt"
        class={`text-sm font-medium transition-colors ${currentPath === '/kontakt' ? 'text-brand-primary' : 'text-slate-600 hover:text-brand-primary'}`}
      >
        Kontakt
      </a>

      <a
        href="tel:504365205"
        class="bg-brand-primary text-white px-6 py-2.5 rounded-sm font-display font-bold text-sm tracking-wide hover:bg-brand-secondary transition-all shadow-lg shadow-brand-primary/20"
      >
        504 365 205
      </a>
    </div>

    <!-- Mobile Menu Button & Sheet -->
    <div class="lg:hidden flex items-center">
      <MobileMenu client:load currentPath={currentPath} />
    </div>
  </div>
</nav>
